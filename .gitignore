# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# WordPress data exports (not needed in repo — data lives in Google Sheets)
/public/*.csv

# WordPress-dumped media (large raw assets, not needed — only key photos kept)
/public/photos/*
!/public/photos/17650_drshweta.jpg
!/public/photos/17677_aboutdoctor.jpg
!/public/photos/17686_Dr__Shweta_Goyal_In_clinic.jpg
!/public/photos/17795_Dr__Shweta_in_Clinic.jpg
!/public/photos/blog/
!/public/photos/blog/**

# Large data files (WordPress dumps, export archives)
data.sql
exports.zip

# Scratch/migration scripts output
/tmp/
